generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Developer {
  id                 String             @id @default(cuid())
  email              String             @unique
  fullName           String?
  companyName        String?
  companyNumber      String?
  domain             String?            // claimed domain for company flow
  website            String?
  jurisdiction       String?
  status             DeveloperStatus    @default(pending)
  apiKey             String             @unique
  verificationTier   Int                @default(1)
  verificationMethod VerificationMethod @default(email)
  verifiedName       String?
  emailVerifiedAt    DateTime?          // set when email link is clicked
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt

  agents              Agent[]
  verificationTokens  VerificationToken[]
  domainVerifications DomainVerification[]
}

model DomainVerification {
  id          String    @id @default(cuid())
  developerId String
  domain      String
  token       String    @unique
  verified    Boolean   @default(false)
  verifiedAt  DateTime?
  createdAt   DateTime  @default(now())
  expiresAt   DateTime  // 7 days from creation

  developer Developer @relation(fields: [developerId], references: [id])

  @@index([developerId])
}

model VerificationToken {
  id          String    @id @default(cuid())
  developerId String
  token       String    @unique
  expiresAt   DateTime
  usedAt      DateTime?
  createdAt   DateTime  @default(now())

  developer Developer @relation(fields: [developerId], references: [id])

  @@index([developerId])
}

model Agent {
  id              String      @id @default(cuid())
  name            String
  description     String?
  did             String      @unique
  publicKey       String
  capabilities    String[]    // canonical capability IDs, populated from card when present
  agentCardUrl    String?     // URL to the A2A Agent Card (/.well-known/agent-card.json)
  agentCardData   Json?       // full Agent Card JSON as fetched
  agentCardSigned Boolean     @default(false) // true when card signature verified against publicKey
  status          AgentStatus @default(unverified)
  developerId     String
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  developer Developer @relation(fields: [developerId], references: [id])
}

model AuditLog {
  id           String   @id @default(cuid())
  agentDid     String?
  action       String
  metadata     Json     @default("{}")
  previousHash String
  recordHash   String
  signature    String
  timestamp    DateTime @default(now())
}

enum DeveloperStatus {
  pending
  verified
  active
}

enum AgentStatus {
  unverified
  active
  revoked
}

enum VerificationMethod {
  email
  individual
  company
}
